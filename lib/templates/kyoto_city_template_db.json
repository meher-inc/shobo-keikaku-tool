        {"id": "beppyo4", "title": "自主検査チェック表（日常）「閉鎖障害等」", "type": "checklist"},
        {"id": "beppyo5", "title": "自主検査チェック表（定期）", "type": "checklist"},
        {"id": "beppyo6", "title": "消防用設備等・特殊消防用設備等自主点検チェック表", "type": "checklist"},
        {"id": "beppyo7", "title": "消防用設備等の法定点検実施計画", "type": "schedule_table"},
        {"id": "beppyo8", "title": "自衛消防隊編成表", "type": "organization_chart"},
        {"id": "beppyo9", "title": "消防訓練実施結果表", "type": "record_table"}
      ]
    },
    {
      "template_id": "kyoto_small",
      "template_name": "小規模・テナント用",
      "target_scale": "小規模防火対象物・テナント",
      "files": {
        "main_template": "01syouboukeikaku.docx",
        "appendix_tables": "02beppyou.docx",
        "sample_filled": "03kinyuurei.pdf",
        "appendix_sample": "04beppyoukinyuuurei.pdf"
      },
      "sections": [
        {"section_id": "s_sec01", "section_number": "第1", "title": "目的と適用範囲", "content_type": "static_with_variables",
          "variables": [
            {"key": "building_name", "label": "建物名", "type": "text", "required": true},
            {"key": "tenant_name", "label": "テナント名", "type": "text", "required": false},
            {"key": "management_floor", "label": "管理権原の及ぶ階", "type": "text", "required": true}
          ]
        },
        {"section_id": "s_sec02", "section_number": "第2", "title": "自衛消防隊の編成及び任務等", "content_type": "dynamic_table", "llm_generation": true,
          "variables": [
            {"key": "team_leader_title", "label": "自衛消防隊長（役職）", "type": "text", "default": "店長"},
            {"key": "roles_assignment", "label": "役割分担", "type": "role_table",
              "roles": [
                {"role": "通報連絡担当", "fire_tasks": ["非常ベル", "119番通報", "消防隊への情報提供"], "earthquake_tasks": ["情報収集担当"]},
                {"role": "初期消火担当", "fire_tasks": ["消火器等で初期消火", "天井延焼時は中止し避難"], "earthquake_tasks": ["点検担当"]},
                {"role": "避難誘導担当", "fire_tasks": ["避難口開放", "避難経路図に従い誘導"], "earthquake_tasks": ["出入口配置", "避難誘導"]}
              ]
            }
          ]
        },
        {"section_id": "s_sec03", "section_number": "第3", "title": "火災予防上の自主検査", "content_type": "static_with_variables",
          "appendix_refs": ["別表1（自主検査表（日常））", "別表2（自主検査表（定期））"],
          "variables": [
            {"key": "daily_inspector", "label": "日常検査実施者", "type": "text", "default": "店長"},
            {"key": "periodic_months", "label": "定期検査実施月", "type": "text", "default": "4月・10月"}
          ]
        },
        {"section_id": "s_sec04", "section_number": "第4", "title": "従業員等の守るべき事項", "content_type": "static"},
        {"section_id": "s_sec05", "section_number": "第5", "title": "放火防止対策", "content_type": "static"},
        {"section_id": "s_sec06", "section_number": "第6", "title": "防火対象物及び消防用設備等の点検", "content_type": "static_with_variables",
          "variables": [
            {"key": "equipment_list", "label": "設備名", "type": "text", "placeholder": "消火器、誘導灯"},
            {"key": "inspection_company", "label": "点検実施者", "type": "text"},
            {"key": "inspection_months", "label": "機器点検月", "type": "text"},
            {"key": "comprehensive_month", "label": "総合点検月", "type": "text"}
          ]
        },
        {"section_id": "s_sec07", "section_number": "第7", "title": "地震対策", "content_type": "static_with_variables",
          "variables": [
            {"key": "temporary_assembly", "label": "一時集合場所", "type": "text", "required": true},
            {"key": "wide_area_evacuation", "label": "広域避難場所", "type": "text", "required": true}
          ]
        },
        {"section_id": "s_sec08", "section_number": "第8", "title": "工事における安全対策", "content_type": "static"},
        {"section_id": "s_sec09", "section_number": "第9", "title": "消防機関への連絡、報告", "content_type": "static_with_variables",
          "variables": [
            {"key": "report_frequency", "label": "点検結果報告頻度", "type": "select",
              "options": [
                {"value": "1年に1回", "label": "特定防火対象物"},
                {"value": "3年に1回", "label": "非特定防火対象物"}
              ]
            }
          ]
        },
        {"section_id": "s_sec10", "section_number": "第10", "title": "統括防火管理者への報告", "content_type": "conditional",
          "condition": "is_unified_management"
        },
        {"section_id": "s_sec11", "section_number": "第11", "title": "防火管理業務の一部委託", "content_type": "conditional",
          "condition": "has_outsourced_management",
          "appendix_ref": "別表3（防火管理業務の一部委託状況表）"
        },
        {"section_id": "s_sec12", "section_number": "第12", "title": "防災教育", "content_type": "dynamic_table",
          "variables": [
            {"key": "education_schedule", "label": "教育スケジュール", "type": "table"}
          ]
        },
        {"section_id": "s_sec13", "section_number": "第13", "title": "訓練", "content_type": "dynamic_table",
          "variables": [
            {"key": "drill_schedule", "label": "訓練スケジュール", "type": "table"}
          ]
        },
        {"section_id": "s_sec14", "section_number": "第14", "title": "その他", "content_type": "freetext"}
      ],
      "appendix_tables": [
        {"id": "s_beppyo1", "title": "自主検査表（日常）", "type": "daily_checklist",
          "columns": ["日", "曜日", "火気使用場所周囲の整理整頓状況", "終業時の火気の確認", "吸い殻の処理", "ガス元栓の閉栓・器具のホース等の劣化損傷の有無", "電気器具の配線の接続状況・劣化損傷の有無", "避難通路・階段等に避難上支障となる物品の有無", "消火器の設置位置の確認・誘導灯等の点灯状況の確認", "可燃物等の放置の有無・倉庫等の施錠の有無の確認"]
        },
        {"id": "s_beppyo2", "title": "自主検査表（定期）", "type": "periodic_checklist",
          "categories": [
            {"category": "建物構造", "items": ["柱・はり・壁・床", "天井", "窓枠・サッシ・ガラス", "外壁・ひさし・パラペット"]},
            {"category": "避難施設", "items": ["避難通路", "階段", "避難階の避難口"]},
            {"category": "火気使用設備器具", "items": ["厨房・給湯設備", "ストーブ"]},
            {"category": "電気設備", "items": ["電気器具"]},
            {"category": "その他", "items": ["危険物（灯油等）"]}
          ]
        },
        {"id": "s_beppyo3", "title": "防火・防災管理業務の一部委託状況表", "type": "form",
          "methods": ["常駐方式", "巡回方式", "遠隔移報方式"]
        }
      ]
    }
  ],
  "required_input_fields": {
    "building_info": [
      {"key": "building_name", "label": "建物名称", "type": "text", "required": true},
      {"key": "building_address", "label": "所在地", "type": "address", "required": true},
      {"key": "building_use", "label": "用途（令別表第一）", "type": "select", "required": true},
      {"key": "is_specific_use", "label": "特定防火対象物か", "type": "auto", "derived_from": "building_use"},
      {"key": "total_area", "label": "延べ面積（㎡）", "type": "number", "required": true},
      {"key": "num_floors", "label": "階数", "type": "number", "required": true},
      {"key": "structure", "label": "構造", "type": "select", "options": ["耐火造", "準耐火造", "その他"]},
      {"key": "capacity", "label": "収容人員", "type": "number", "required": true}
    ],
    "management_info": [
      {"key": "owner_name", "label": "管理権原者氏名", "type": "text", "required": true},
      {"key": "manager_name", "label": "防火管理者氏名", "type": "text", "required": true},
      {"key": "manager_qualification", "label": "防火管理者資格種別", "type": "select", "options": ["甲種", "乙種"], "required": true},
      {"key": "manager_appointment_date", "label": "選任年月日", "type": "date", "required": true},
      {"key": "manager_contact", "label": "連絡先", "type": "tel", "required": true}
    ],
    "equipment_info": [
      {"key": "fire_equipment", "label": "消防用設備等", "type": "multi_select", "options": [
        "消火器", "屋内消火栓", "スプリンクラー設備", "自動火災報知設備",
        "漏電火災警報器", "非常警報設備", "避難器具", "誘導灯",
        "連結散水設備", "連結送水管", "非常コンセント設備", "排煙設備"
      ]},
      {"key": "inspection_company", "label": "点検委託先", "type": "text"},
      {"key": "security_company", "label": "警備会社", "type": "text"}
    ]
  },
  "template_selection_logic": {
    "rules": [
      {
        "condition": "total_area <= 500 OR is_tenant",
        "template": "kyoto_small",
        "label": "小規模・テナント用"
      },
      {
        "condition": "total_area > 500",
        "template": "kyoto_medium",
        "label": "中規模用"
      }
    ],
    "note": "大規模用テンプレートは京都市消防局では現在未公開。大規模物件は個別対応推奨。"
  }
}
