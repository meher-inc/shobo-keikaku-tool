{
  "version": "1.0",
  "packName": "hazmat-prevention-rules-approval",
  "title": "予防規程 制定・変更 認可申請書",
  "legalRef": "様式第26（第62条関係）",
  "summary": "危険物の規制に関する政令第37条の規定により予防規程を制定または変更する際に、市町村長等の認可を受けるための申請書。",
  "consultProfessional": true,
  "preamble": "下記のとおり、予防規程の{{operationType}}認可を受けたいので申請します。",
  "submitToTemplate": "{{municipality}}長　殿",
  "submitterTitle": "申請者",
  "submitterFields": [
    { "key": "submitterAddress", "label": "住所", "type": "text", "required": true },
    { "key": "submitterPhone", "label": "電話番号", "type": "text", "required": true },
    { "key": "submitterName", "label": "氏名（法人の場合は名称及び代表者氏名）", "type": "text", "required": true }
  ],
  "headerFields": [
    { "key": "operationType", "label": "申請区分", "type": "radio", "options": ["制定", "変更"], "required": true },
    { "key": "submitDate", "label": "申請日", "type": "date", "required": true },
    { "key": "municipality", "label": "提出先（市町村長等）", "type": "text", "required": true }
  ],
  "sections": [
    {
      "id": "owner",
      "heading": "設置者",
      "fields": [
        { "key": "ownerAddress", "label": "住所", "type": "text", "required": true },
        { "key": "ownerPhone", "label": "電話番号", "type": "text" },
        { "key": "ownerName", "label": "氏名（法人の場合は名称及び代表者氏名）", "type": "text", "required": true }
      ]
    },
    {
      "id": "facility",
      "heading": "対象施設",
      "fields": [
        { "key": "facilityLocation", "label": "設置場所", "type": "text", "required": true },
        { "key": "facilityKind", "label": "製造所等の別", "type": "text", "required": true },
        { "key": "facilityCategory", "label": "貯蔵所又は取扱所の区分", "type": "text" },
        { "key": "permitDate", "label": "設置の許可年月日", "type": "date", "required": true },
        { "key": "permitNumber", "label": "設置の許可番号", "type": "text", "required": true },
        { "key": "hazmatClassAndName", "label": "危険物の類、品名（指定数量）、最大数量", "type": "multiline", "required": true },
        { "key": "designatedQuantityMultiple", "label": "指定数量の倍数", "type": "text", "required": true }
      ]
    },
    {
      "id": "rules",
      "heading": "予防規程",
      "fields": [
        { "key": "rulesDate", "label": "予防規程 作成・変更年月日", "type": "date", "required": true }
      ]
    }
  ],
  "footnotes": [
    "この用紙の大きさは、日本産業規格Ａ4とすること。",
    "法人にあっては名称、代表者氏名及び主たる事務所の所在地を記入すること。",
    "予防規程本文は別途添付すること。",
    "変更申請の場合は、変更対比表または変更前後の予防規程を別途添付すること。",
    "受付欄・備考欄は記入しないこと。"
  ]
}
