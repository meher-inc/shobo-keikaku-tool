{
  "version": "1.0",
  "packName": "building-use-start",
  "title": "防火対象物使用開始届出書",
  "legalRef": "第3号様式の2（火災予防条例 第12条の2関係）",
  "summary": "防火対象物またはその部分の使用を開始する際に、使用開始7日前までに所轄消防署長へ提出する届出書。",
  "preamble": "下記のとおり、防火対象物又はその部分の使用を開始したいので、火災予防条例第56条の2第1項の規定に基づき届け出ます。",
  "submitToTemplate": "{{fireAuthorityName}}　{{fireDeptName}}消防署長　殿",
  "submitterTitle": "届出者",
  "submitterFields": [
    {
      "key": "submitterAddress",
      "label": "申請者・届出者 住所",
      "type": "text",
      "required": true
    },
    {
      "key": "submitterName",
      "label": "申請者・届出者 氏名",
      "type": "text",
      "required": true,
      "placeholder": "法人の場合は名称及び代表者氏名"
    },
    {
      "key": "submitterPhone",
      "label": "申請者・届出者 電話番号",
      "type": "text",
      "required": true
    }
  ],
  "headerFields": [
    {
      "key": "submitDate",
      "label": "提出日",
      "type": "date",
      "required": true
    },
    {
      "key": "municipality",
      "label": "市町村",
      "type": "text",
      "required": true,
      "placeholder": "例: 京都市"
    },
    {
      "key": "recipientTitle",
      "label": "提出先肩書",
      "type": "text",
      "required": true,
      "placeholder": "例: 消防署長"
    }
  ],
  "sections": [
    {
      "id": "building",
      "heading": "建築物の情報",
      "fields": [
        {
          "key": "buildingAddress",
          "label": "所在地",
          "type": "text",
          "required": true
        },
        {
          "key": "buildingPhone",
          "label": "建物電話番号",
          "type": "text"
        },
        {
          "key": "buildingName",
          "label": "建物名称",
          "type": "text",
          "required": true
        },
        {
          "key": "mainUse",
          "label": "主要用途",
          "type": "text",
          "required": true,
          "placeholder": "例: 事務所"
        }
      ]
    },
    {
      "id": "construction",
      "heading": "確認・同意・工期",
      "fields": [
        {
          "key": "buildingConfirmationDate",
          "label": "建築確認年月日",
          "type": "date"
        },
        {
          "key": "buildingConfirmationNumber",
          "label": "建築確認番号",
          "type": "text"
        },
        {
          "key": "fireConsentDate",
          "label": "消防同意年月日",
          "type": "date"
        },
        {
          "key": "fireConsentNumber",
          "label": "消防同意番号",
          "type": "text"
        },
        {
          "key": "constructionStartDate",
          "label": "工事着手年月日",
          "type": "date"
        },
        {
          "key": "constructionCompleteDate",
          "label": "工事完了 (予定) 年月日",
          "type": "date"
        },
        {
          "key": "constructionEndDate",
          "label": "使用開始 (予定) 年月日",
          "type": "date",
          "required": true
        },
        {
          "key": "otherPermits",
          "label": "他の法令による許認可",
          "type": "multiline",
          "placeholder": "例: なし"
        }
      ]
    },
    {
      "id": "scale",
      "heading": "規模・人員",
      "fields": [
        {
          "key": "siteArea",
          "label": "敷地面積 (㎡)",
          "type": "text"
        },
        {
          "key": "buildingArea",
          "label": "建築面積 (㎡)",
          "type": "text"
        },
        {
          "key": "totalArea",
          "label": "延面積 (㎡)",
          "type": "text"
        },
        {
          "key": "employeeCount",
          "label": "従業員数 (人)",
          "type": "text"
        },
        {
          "key": "businessHours",
          "label": "公開時間又は従業時間",
          "type": "text",
          "placeholder": "例: 9:00〜18:00"
        },
        {
          "key": "fireEquipment",
          "label": "屋外消火栓・動力消防ポンプ・消防用水の概要",
          "type": "multiline"
        },
        {
          "key": "remarks",
          "label": "その他必要事項",
          "type": "multiline"
        }
      ]
    },
    {
      "id": "official-use",
      "heading": "※ 行政記入欄 (通常は空欄)",
      "description": "行政側が記入する欄です。",
      "fields": [
        {
          "key": "officialUseReceipt",
          "label": "※受付欄 (行政記入)",
          "type": "text",
          "helpText": "行政側で記入されます。通常は空欄のままで提出。"
        },
        {
          "key": "officialUseProgress",
          "label": "※経過欄 (行政記入)",
          "type": "text",
          "helpText": "行政側で記入されます。"
        }
      ]
    }
  ],
  "footnotes": [
    "この用紙の大きさは、日本産業規格Ａ列4番とすること。",
    "届出者が法人の場合、氏名欄にはその名称及び代表者氏名を記入すること。",
    "事業所欄は、事業所に関する届出の場合のみ記入すること。",
    "添付図書（概要表・平面図・立面図・断面図・室内仕上表・建具表 等）は別途用意のうえ提出すること。"
  ]
}
