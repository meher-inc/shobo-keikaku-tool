{
  "version": "1.0",
  "packName": "hazmat-temporary-storage",
  "title": "危険物仮貯蔵・仮取扱い承認申請書",
  "legalRef": "様式第1の2（第1条の6関係）",
  "summary": "指定数量以上の危険物を、所轄消防長または消防署長の承認を受けて10日以内の期間に限り、製造所等以外の場所で仮貯蔵または仮取扱いする際の申請書。",
  "consultProfessional": true,
  "preamble": "下記のとおり、危険物の{{operationKind}}の承認を受けたいので申請します。",
  "submitToTemplate": "{{authority}}　殿",
  "submitterTitle": "申請者",
  "submitterFields": [
    {
      "key": "submitterAddress",
      "label": "申請者・届出者 住所",
      "type": "text",
      "required": true
    },
    {
      "key": "submitterName",
      "label": "申請者・届出者 氏名",
      "type": "text",
      "required": true,
      "placeholder": "法人の場合は名称及び代表者氏名"
    },
    {
      "key": "submitterPhone",
      "label": "申請者・届出者 電話番号",
      "type": "text",
      "required": true
    }
  ],
  "headerFields": [
    {
      "key": "submitDate",
      "label": "提出日",
      "type": "date",
      "required": true
    },
    {
      "key": "municipality",
      "label": "市町村",
      "type": "text",
      "required": true,
      "placeholder": "例: 京都市"
    },
    {
      "key": "recipientTitle",
      "label": "提出先肩書",
      "type": "text",
      "required": true,
      "placeholder": "例: 消防署長"
    }
  ],
  "sections": [
    {
      "id": "owner",
      "heading": "危険物の所有者・管理者・占有者",
      "fields": [
        {
          "key": "ownerAddress",
          "label": "設置者 住所",
          "type": "text",
          "required": true
        },
        {
          "key": "ownerName",
          "label": "設置者 氏名",
          "type": "text",
          "required": true
        },
        {
          "key": "ownerPhone",
          "label": "設置者 電話番号",
          "type": "text"
        },
        {
          "key": "ownerExtraInfo",
          "label": "補助情報",
          "type": "text"
        }
      ]
    },
    {
      "id": "temporary",
      "heading": "仮貯蔵・仮取扱い情報",
      "fields": [
        {
          "key": "temporaryLocation",
          "label": "仮貯蔵・仮取扱いの場所 (所在地・名称)",
          "type": "text",
          "required": true
        },
        {
          "key": "hazmatClassAndName",
          "label": "危険物の類、品名（指定数量）、最大数量",
          "type": "multiline",
          "required": true,
          "placeholder": "例: 第4類 第1石油類（200L） 最大1,000L"
        },
        {
          "key": "designatedQuantityMultiple",
          "label": "指定数量の倍数",
          "type": "text",
          "required": true
        },
        {
          "key": "temporaryMethod",
          "label": "仮貯蔵・仮取扱いの方法",
          "type": "multiline",
          "required": true
        },
        {
          "key": "temporaryPeriod",
          "label": "仮貯蔵・仮取扱いの期間",
          "type": "text",
          "required": true,
          "placeholder": "例: 令和8年6月1日から令和8年6月10日まで 10日間"
        },
        {
          "key": "managementStatus",
          "label": "管理の状況 (消火設備の設置状況を含む)",
          "type": "multiline",
          "required": true
        }
      ]
    },
    {
      "id": "manager",
      "heading": "現場管理責任者",
      "fields": [
        {
          "key": "siteManagerAddress",
          "label": "現場管理責任者 住所",
          "type": "text",
          "required": true
        },
        {
          "key": "siteManagerName",
          "label": "現場管理責任者 氏名",
          "type": "text",
          "required": true
        },
        {
          "key": "siteManagerEmergencyContact",
          "label": "緊急連絡先",
          "type": "text",
          "required": true
        },
        {
          "key": "siteManagerLicense",
          "label": "危険物取扱者免状の種類",
          "type": "text",
          "placeholder": "例: 甲種、または 無"
        }
      ]
    },
    {
      "id": "other",
      "heading": "理由・その他",
      "fields": [
        {
          "key": "temporaryReason",
          "label": "仮貯蔵・仮取扱いの理由及び期間経過後の処理",
          "type": "multiline",
          "required": true
        },
        {
          "key": "otherMatters",
          "label": "その他必要な事項",
          "type": "multiline"
        }
      ]
    },
    {
      "id": "official",
      "heading": "※ 行政記入欄",
      "fields": [
        {
          "key": "officialUseReceipt",
          "label": "※受付欄 (行政記入)",
          "type": "text",
          "helpText": "行政側で記入されます。通常は空欄のままで提出。"
        },
        {
          "key": "officialApprovalDateAndNumber",
          "label": "※承認年月日・承認番号 (行政記入)",
          "type": "text"
        },
        {
          "key": "officialUseFee",
          "label": "※手数料欄 (行政記入)",
          "type": "text"
        }
      ]
    }
  ],
  "footnotes": [
    "この用紙の大きさは、日本産業規格Ａ4とすること。",
    "法人にあっては名称、代表者氏名及び主たる事務所の所在地を記入すること。",
    "案内図、配置図、平面図、構造図その他関係書類を別途添付すること。",
    "受付欄・経過欄・手数料欄・承認年月日・承認番号は記入しないこと。"
  ]
}
