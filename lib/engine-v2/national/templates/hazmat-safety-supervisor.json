{
  "version": "1.0",
  "packName": "hazmat-safety-supervisor",
  "title": "危険物保安監督者 選任・解任届出書",
  "legalRef": "様式第20（第48条の3関係）",
  "summary": "危険物製造所等における危険物保安監督者を選任または解任した際に、市町村長等へ提出する全国統一様式。",
  "preamble": "下記のとおり、危険物保安監督者を{{operationType}}したので届け出ます。",
  "submitToTemplate": "{{municipality}}長　殿",
  "submitterTitle": "届出者",
  "submitterFields": [
    {
      "key": "submitterAddress",
      "label": "申請者・届出者 住所",
      "type": "text",
      "required": true
    },
    {
      "key": "submitterName",
      "label": "申請者・届出者 氏名",
      "type": "text",
      "required": true,
      "placeholder": "法人の場合は名称及び代表者氏名"
    },
    {
      "key": "submitterPhone",
      "label": "申請者・届出者 電話番号",
      "type": "text",
      "required": true
    }
  ],
  "headerFields": [
    {
      "key": "submitDate",
      "label": "提出日",
      "type": "date",
      "required": true
    },
    {
      "key": "municipality",
      "label": "市町村",
      "type": "text",
      "required": true,
      "placeholder": "例: 京都市"
    },
    {
      "key": "recipientTitle",
      "label": "提出先肩書",
      "type": "text",
      "required": true,
      "placeholder": "例: 消防署長"
    }
  ],
  "sections": [
    {
      "id": "owner",
      "heading": "設置者 (危険物の所有者)",
      "fields": [
        {
          "key": "ownerAddress",
          "label": "設置者 住所",
          "type": "text",
          "required": true
        },
        {
          "key": "ownerName",
          "label": "設置者 氏名",
          "type": "text",
          "required": true
        },
        {
          "key": "ownerPhone",
          "label": "設置者 電話番号",
          "type": "text"
        }
      ]
    },
    {
      "id": "facility",
      "heading": "対象施設",
      "fields": [
        {
          "key": "facilityKind",
          "label": "製造所等の別",
          "type": "text",
          "required": true,
          "placeholder": "例: 屋内貯蔵所"
        },
        {
          "key": "facilityCategory",
          "label": "貯蔵所又は取扱所の区分",
          "type": "text",
          "placeholder": "例: 一般取扱所"
        },
        {
          "key": "permitInfo",
          "label": "設置の許可年月日及び許可番号",
          "type": "text",
          "placeholder": "例: 令和7年1月1日 第1号"
        },
        {
          "key": "facilityLocation",
          "label": "設置場所",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "id": "appointment",
      "heading": "保安監督者 選任・解任",
      "fields": [
        {
          "key": "appointedName",
          "label": "選任 氏名",
          "type": "text"
        },
        {
          "key": "appointedLicense",
          "label": "選任 免状の種類",
          "type": "text",
          "placeholder": "例: 甲種危険物取扱者"
        },
        {
          "key": "appointmentDate",
          "label": "選任年月日",
          "type": "date"
        },
        {
          "key": "dismissedName",
          "label": "解任 氏名",
          "type": "text"
        },
        {
          "key": "dismissedLicense",
          "label": "解任 免状の種類",
          "type": "text"
        },
        {
          "key": "dismissalDate",
          "label": "解任年月日",
          "type": "date"
        }
      ]
    },
    {
      "id": "official",
      "heading": "※ 行政記入欄",
      "fields": [
        {
          "key": "officialUseReceipt",
          "label": "※受付欄 (行政記入)",
          "type": "text",
          "helpText": "行政側で記入されます。通常は空欄のままで提出。"
        },
        {
          "key": "officialUseRemarks",
          "label": "※備考欄 (行政記入)",
          "type": "text"
        }
      ]
    }
  ],
  "footnotes": [
    "この用紙の大きさは、日本産業規格Ａ4とすること。",
    "法人にあっては名称、代表者氏名及び主たる事務所の所在地を記入すること。",
    "受付欄・備考欄は記入しないこと。"
  ]
}
