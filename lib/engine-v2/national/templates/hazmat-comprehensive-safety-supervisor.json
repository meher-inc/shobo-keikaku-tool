{
  "version": "1.0",
  "packName": "hazmat-comprehensive-safety-supervisor",
  "title": "危険物保安統括管理者 選任・解任届出書",
  "legalRef": "様式第19（第47条の6関係）",
  "summary": "同一事業所において指定数量3,000倍以上の危険物を貯蔵または取り扱う製造所等を有する事業所において、危険物保安統括管理者を選任または解任した際の届出書。",
  "consultProfessional": true,
  "preamble": "下記のとおり、危険物保安統括管理者を{{operationType}}したので届け出ます。",
  "submitToTemplate": "{{municipality}}長　殿",
  "submitterTitle": "届出者",
  "submitterFields": [
    {
      "key": "submitterAddress",
      "label": "申請者・届出者 住所",
      "type": "text",
      "required": true
    },
    {
      "key": "submitterName",
      "label": "申請者・届出者 氏名",
      "type": "text",
      "required": true,
      "placeholder": "法人の場合は名称及び代表者氏名"
    },
    {
      "key": "submitterPhone",
      "label": "申請者・届出者 電話番号",
      "type": "text",
      "required": true
    }
  ],
  "headerFields": [
    {
      "key": "submitDate",
      "label": "提出日",
      "type": "date",
      "required": true
    },
    {
      "key": "municipality",
      "label": "市町村",
      "type": "text",
      "required": true,
      "placeholder": "例: 京都市"
    },
    {
      "key": "recipientTitle",
      "label": "提出先肩書",
      "type": "text",
      "required": true,
      "placeholder": "例: 消防署長"
    }
  ],
  "sections": [
    {
      "id": "facility",
      "heading": "対象事業所",
      "fields": [
        {
          "key": "facilityLocationAndName",
          "label": "事業所の設置場所及び名称",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "id": "appointment",
      "heading": "統括管理者 選任・解任",
      "fields": [
        {
          "key": "appointedName",
          "label": "選任 氏名",
          "type": "text"
        },
        {
          "key": "appointedPosition",
          "label": "選任 職務上の地位",
          "type": "text"
        },
        {
          "key": "appointmentDate",
          "label": "選任年月日",
          "type": "date"
        },
        {
          "key": "dismissedName",
          "label": "解任 氏名",
          "type": "text"
        },
        {
          "key": "dismissedPosition",
          "label": "解任 職務上の地位",
          "type": "text"
        },
        {
          "key": "dismissalDate",
          "label": "解任年月日",
          "type": "date"
        }
      ]
    },
    {
      "id": "official",
      "heading": "※ 行政記入欄",
      "fields": [
        {
          "key": "officialUseReceipt",
          "label": "※受付欄 (行政記入)",
          "type": "text",
          "helpText": "行政側で記入されます。通常は空欄のままで提出。"
        },
        {
          "key": "officialUseRemarks",
          "label": "※備考欄 (行政記入)",
          "type": "text"
        }
      ]
    }
  ],
  "footnotes": [
    "この用紙の大きさは、日本産業規格Ａ4とすること。",
    "法人にあっては名称、代表者氏名及び主たる事務所の所在地を記入すること。",
    "受付欄・備考欄は記入しないこと。"
  ]
}
