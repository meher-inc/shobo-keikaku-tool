{
  "version": "1.0",
  "packName": "event-hosting-notification",
  "title": "催物開催届出書",
  "legalRef": "火災予防条例 第10号様式の3（第13条関係）等",
  "summary": "劇場・ディスコ・展示場等で催物を開催する際に、所轄消防署長へ提出する火災予防条例準拠様式。観覧場・展示場等での催物が対象。",
  "preamble": "{{municipality}}火災予防条例の規定により催物を開催するので届け出ます。",
  "submitToTemplate": "{{municipality}} {{fireDeptName}}消防署長　殿",
  "submitterTitle": "届出者",
  "submitterFields": [
    { "key": "submitterAddress", "label": "住所（法人の場合は主たる事務所の所在地）", "type": "text", "required": true },
    { "key": "submitterName", "label": "氏名（法人の場合は名称及び代表者名）", "type": "text", "required": true },
    { "key": "submitterPhone", "label": "電話番号", "type": "text", "required": true }
  ],
  "headerFields": [
    { "key": "submitDate", "label": "届出日", "type": "date", "required": true },
    { "key": "municipality", "label": "提出先（市区町村）", "type": "text", "required": true },
    { "key": "fireDeptName", "label": "提出先（管轄消防署）", "type": "text", "required": true }
  ],
  "sections": [
    {
      "id": "building",
      "heading": "防火対象物",
      "fields": [
        { "key": "buildingAddress", "label": "所在地", "type": "text", "required": true },
        { "key": "buildingPhone", "label": "電話番号", "type": "text" },
        { "key": "buildingName", "label": "名称", "type": "text", "required": true },
        { "key": "buildingCategory", "label": "用途（消防法施行令別表第1の項番）", "type": "text", "required": true, "placeholder": "例：（1）項イ" }
      ]
    },
    {
      "id": "venue",
      "heading": "催物に使用する場所",
      "fields": [
        { "key": "venuePosition", "label": "位置", "type": "text", "required": true, "placeholder": "例：3階多目的ホール" },
        { "key": "venueArea", "label": "面積（㎡）", "type": "text", "required": true },
        { "key": "seatStructure", "label": "客席の構造", "type": "multiline", "required": true, "placeholder": "例：固定席800席／可動席200席" },
        { "key": "fireEquipmentSummary", "label": "消防用設備等又は特殊消防用設備等の概要", "type": "multiline", "required": true }
      ]
    },
    {
      "id": "event",
      "heading": "催物の内容",
      "fields": [
        { "key": "eventUse", "label": "用途", "type": "checkbox-group", "options": ["劇場等", "ディスコ等", "展示場"], "required": true },
        { "key": "eventStartDate", "label": "開催期間（開始日）", "type": "date", "required": true },
        { "key": "eventEndDate", "label": "開催期間（終了日）", "type": "date", "required": true },
        { "key": "eventStartTime", "label": "開催時間（開始）", "type": "text", "required": true, "placeholder": "例：18:00" },
        { "key": "eventEndTime", "label": "開催時間（終了）", "type": "text", "required": true, "placeholder": "例：21:30" },
        { "key": "capacity", "label": "収容人員（人）", "type": "text", "required": true },
        { "key": "fireManagerName", "label": "防火管理者の氏名", "type": "text", "required": true },
        { "key": "emergencyPersonnel", "label": "避難誘導及び消火活動に従事できる人員（人）", "type": "text", "required": true }
      ]
    }
  ],
  "footnotes": [
    "使用する防火対象物の略図を別途添付すること。",
    "本様式は火災予防条例に基づくため、自治体ごとに様式番号・項目構成が異なる場合がある。京都市は第10号様式の3（第13条関係）を準拠としている。"
  ]
}
