{
  "version": "1.0",
  "packName": "hazmat-temporary-use",
  "title": "危険物製造所等 仮使用承認申請書",
  "legalRef": "様式第7（第5条の2関係）",
  "summary": "危険物製造所・貯蔵所・取扱所の変更工事中、変更工事に係る部分以外の部分を仮使用しようとする際に、市町村長等の承認を受けるための申請書。",
  "consultProfessional": true,
  "preamble": "下記のとおり、危険物製造所等の仮使用の承認を受けたいので申請します。",
  "submitToTemplate": "{{municipality}}長　殿",
  "submitterTitle": "申請者",
  "submitterFields": [
    {
      "key": "submitterAddress",
      "label": "申請者・届出者 住所",
      "type": "text",
      "required": true
    },
    {
      "key": "submitterName",
      "label": "申請者・届出者 氏名",
      "type": "text",
      "required": true,
      "placeholder": "法人の場合は名称及び代表者氏名"
    },
    {
      "key": "submitterPhone",
      "label": "申請者・届出者 電話番号",
      "type": "text",
      "required": true
    }
  ],
  "headerFields": [
    {
      "key": "submitDate",
      "label": "提出日",
      "type": "date",
      "required": true
    },
    {
      "key": "municipality",
      "label": "市町村",
      "type": "text",
      "required": true,
      "placeholder": "例: 京都市"
    },
    {
      "key": "recipientTitle",
      "label": "提出先肩書",
      "type": "text",
      "required": true,
      "placeholder": "例: 消防署長"
    }
  ],
  "sections": [
    {
      "id": "facility",
      "heading": "対象施設",
      "fields": [
        {
          "key": "facilityLocation",
          "label": "設置場所",
          "type": "text",
          "required": true
        },
        {
          "key": "facilityKind",
          "label": "製造所等の別",
          "type": "text",
          "required": true,
          "placeholder": "例: 屋内貯蔵所"
        },
        {
          "key": "facilityCategory",
          "label": "貯蔵所又は取扱所の区分",
          "type": "text",
          "placeholder": "例: 一般取扱所"
        }
      ]
    },
    {
      "id": "change",
      "heading": "変更許可情報",
      "fields": [
        {
          "key": "changePermitApplicationDate",
          "label": "変更許可申請年月日",
          "type": "date",
          "required": true
        },
        {
          "key": "changePermitInfo",
          "label": "変更の許可年月日及び許可番号",
          "type": "text"
        },
        {
          "key": "temporaryUseScope",
          "label": "仮使用の承認を申請する部分",
          "type": "multiline",
          "required": true,
          "placeholder": "例: 別添図面のとおり"
        }
      ]
    },
    {
      "id": "official",
      "heading": "※ 行政記入欄",
      "fields": [
        {
          "key": "officialUseReceipt",
          "label": "※受付欄 (行政記入)",
          "type": "text",
          "helpText": "行政側で記入されます。通常は空欄のままで提出。"
        },
        {
          "key": "officialApprovalDateAndNumber",
          "label": "※承認年月日・承認番号 (行政記入)",
          "type": "text"
        },
        {
          "key": "officialUseFee",
          "label": "※手数料欄 (行政記入)",
          "type": "text"
        }
      ]
    }
  ],
  "footnotes": [
    "この用紙の大きさは、日本産業規格Ａ4とすること。",
    "法人にあっては名称、代表者氏名及び主たる事務所の所在地を記入すること。",
    "変更許可前/後のいずれかの欄に記入し、記入しない欄には斜線を入れること。",
    "受付欄・経過欄・手数料欄・承認年月日・承認番号は記入しないこと。"
  ]
}
