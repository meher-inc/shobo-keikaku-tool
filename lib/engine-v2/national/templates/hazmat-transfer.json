{
  "version": "1.0",
  "packName": "hazmat-transfer",
  "title": "危険物製造所等 譲渡引渡届出書",
  "legalRef": "様式第15（第7条関係）",
  "summary": "危険物製造所・貯蔵所・取扱所の譲渡または引渡しがあった際に、譲受人または引渡を受けた者が市町村長等へ提出する全国統一様式。",
  "consultProfessional": true,
  "preamble": "下記のとおり、危険物製造所等の譲渡又は引渡しがあったので届け出ます。",
  "submitToTemplate": "{{municipality}}長　殿",
  "submitterTitle": "届出者",
  "submitterFields": [
    {
      "key": "submitterAddress",
      "label": "申請者・届出者 住所",
      "type": "text",
      "required": true
    },
    {
      "key": "submitterName",
      "label": "申請者・届出者 氏名",
      "type": "text",
      "required": true,
      "placeholder": "法人の場合は名称及び代表者氏名"
    },
    {
      "key": "submitterPhone",
      "label": "申請者・届出者 電話番号",
      "type": "text",
      "required": true
    }
  ],
  "headerFields": [
    {
      "key": "submitDate",
      "label": "提出日",
      "type": "date",
      "required": true
    },
    {
      "key": "municipality",
      "label": "市町村",
      "type": "text",
      "required": true,
      "placeholder": "例: 京都市"
    },
    {
      "key": "recipientTitle",
      "label": "提出先肩書",
      "type": "text",
      "required": true,
      "placeholder": "例: 消防署長"
    }
  ],
  "sections": [
    {
      "id": "receiver",
      "heading": "譲渡又は引渡を受けた者",
      "fields": [
        {
          "key": "ownerAddress",
          "label": "設置者 住所",
          "type": "text",
          "required": true
        },
        {
          "key": "ownerName",
          "label": "設置者 氏名",
          "type": "text",
          "required": true
        },
        {
          "key": "ownerPhone",
          "label": "設置者 電話番号",
          "type": "text"
        }
      ]
    },
    {
      "id": "transferor",
      "heading": "譲渡又は引渡をした者",
      "fields": [
        {
          "key": "transferorAddress",
          "label": "前所有者 住所",
          "type": "text",
          "required": true
        },
        {
          "key": "transferorName",
          "label": "前所有者 氏名",
          "type": "text",
          "required": true
        },
        {
          "key": "transferorPhone",
          "label": "前所有者 電話番号",
          "type": "text"
        }
      ]
    },
    {
      "id": "facility",
      "heading": "対象施設",
      "fields": [
        {
          "key": "transferFacilitySection",
          "label": "施設セクション見出し",
          "type": "text",
          "helpText": "通常は「対象施設」など。空欄可。"
        },
        {
          "key": "facilityLocation",
          "label": "設置場所",
          "type": "text",
          "required": true
        },
        {
          "key": "facilityKind",
          "label": "製造所等の別",
          "type": "text",
          "required": true,
          "placeholder": "例: 屋内貯蔵所"
        },
        {
          "key": "facilityCategory",
          "label": "貯蔵所又は取扱所の区分",
          "type": "text",
          "placeholder": "例: 一般取扱所"
        },
        {
          "key": "permitInfo",
          "label": "設置の許可年月日及び許可番号",
          "type": "text",
          "placeholder": "例: 令和7年1月1日 第1号"
        },
        {
          "key": "inspectionInfo",
          "label": "設置の完成検査年月日及び検査番号",
          "type": "text",
          "placeholder": "例: 令和7年3月1日 第2号"
        },
        {
          "key": "hazmatClassAndName",
          "label": "危険物の類、品名（指定数量）、最大数量",
          "type": "multiline",
          "required": true,
          "placeholder": "例: 第4類 第1石油類（200L） 最大1,000L"
        },
        {
          "key": "designatedQuantityMultiple",
          "label": "指定数量の倍数",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "id": "reason",
      "heading": "理由",
      "fields": [
        {
          "key": "transferReason",
          "label": "譲渡又は引渡のあった理由",
          "type": "multiline",
          "required": true,
          "placeholder": "例: 売買、相続、合併"
        }
      ]
    },
    {
      "id": "official",
      "heading": "※ 行政記入欄",
      "fields": [
        {
          "key": "officialUseReceipt",
          "label": "※受付欄 (行政記入)",
          "type": "text",
          "helpText": "行政側で記入されます。通常は空欄のままで提出。"
        },
        {
          "key": "officialUseProgress",
          "label": "※経過欄 (行政記入)",
          "type": "text",
          "helpText": "行政側で記入されます。"
        }
      ]
    }
  ],
  "footnotes": [
    "この用紙の大きさは、日本産業規格Ａ4とすること。",
    "法人にあっては名称、代表者氏名及び主たる事務所の所在地を記入すること。",
    "譲渡引渡を証明する書類（売買契約書／登記事項証明書／合併契約書 等）を別途添付すること。",
    "受付欄・経過欄は記入しないこと。"
  ]
}
